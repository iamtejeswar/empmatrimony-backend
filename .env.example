# ==============================================
# MATRIMONY PLATFORM - ENVIRONMENT CONFIGURATION
# ==============================================
# Copy this file to .env and fill in your values

# ---- SERVER ----
NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_NAME=MatrimonyPlatform
FRONTEND_URL=http://localhost:3000

# ---- DATABASE (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=matrimony_db
DB_USER=postgres
DB_PASSWORD=admin
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_MIN=2

# ---- JWT ----
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=30d

# ---- GOOGLE OAUTH2 ----
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback

# ---- EMAIL (Gmail SMTP) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=MatrimonyPlatform <noreply@matrimony.com>

# ---- OTP ----
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# ---- AWS S3 (Document Storage) ----
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=matrimony-documents

# ---- RATE LIMITING ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_MAX=5

# ---- ADMIN ----
ADMIN_EMAIL=admin@matrimony.com
ADMIN_PASSWORD=SecureAdmin@123

# ---- ENCRYPTION ----
DOCUMENT_ENCRYPTION_KEY=your_32_char_encryption_key_here!

# ---- LOGGING ----
LOG_LEVEL=info
LOG_FILE=logs/app.log
